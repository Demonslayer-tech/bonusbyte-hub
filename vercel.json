{
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self' https://*.telegram.org https://*.ton.org" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}